# PostgreSQL connection (Railway or local)
DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: Vercel Blob for image uploads (easiest – set in Vercel when you create a Blob store)
# When set, post images and avatars are stored on Vercel Blob. No FTP or subdomain needed.
# BLOB_READ_WRITE_TOKEN is added automatically when you create a Blob store in the project’s Storage tab.

# Optional: SiteGround FTP for persistent image uploads (used only if BLOB_READ_WRITE_TOKEN is not set)
# If set, uploads go to SiteGround instead of local public/uploads
# FTP_REMOTE_DIR = path on server, e.g. public_html/uploads
# FTP_PUBLIC_URL = public base URL for those files, e.g. https://outkry.com/uploads
FTP_HOST=c119567.sgvps.net
FTP_USER=admin@outkry.com
FTP_PASSWORD=your_ftp_password
FTP_REMOTE_DIR=public_html/uploads
FTP_PUBLIC_URL=https://outkry.com/uploads
# FTP_SECURE=true
